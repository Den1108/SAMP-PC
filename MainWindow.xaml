<Window x:Class="SAMPLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Flyt RP Launcher" Height="720" Width="1280" 
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True" WindowStyle="None" Background="Transparent">
    
    <Window.Resources>
        <Style x:Key="SocialButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2D34"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="20"/>
                </Style>
            </Style.Resources>
        </Style>
        
        <Style x:Key="NewsCard" TargetType="Border">
            <Setter Property="Background" Value="#1E2124"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Width" Value="300"/>
        </Style>
    </Window.Resources>

    <Border Background="#0D0F12" CornerRadius="20" MouseDown="Header_MouseDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="30,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="FLYT RP" Foreground="#32CD32" FontSize="28" FontWeight="Black" VerticalAlignment="Center" Grid.Column="0" FontStyle="Italic"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="40,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="ГЛАВНАЯ" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,30,0" Cursor="Hand"/>
                    <TextBlock Text="НОВОСТИ" Foreground="#8A8F98" FontSize="14" FontWeight="Bold" Margin="0,0,30,0" Cursor="Hand"/>
                    <TextBlock Text="ФОРУМ" Foreground="#8A8F98" FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SocialButton}" Content="VK"/>
                    <Button Style="{StaticResource SocialButton}" Content="DS"/>
                    <Button Style="{StaticResource SocialButton}" Content="TG"/>
                    
                    <Button Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Close_Click" Margin="20,0,0,0">
                        <TextBlock Text="✕" Foreground="#8A8F98" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Margin="30,10,30,20" CornerRadius="20" Background="#1A1D21" ClipToBounds="True">
                <Grid>
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="40,40">
                        <TextBlock Text="ОБНОВЛЕНИЕ" Foreground="#32CD32" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="ЛЕТНИЙ СЕЗОН" Foreground="White" FontSize="48" FontWeight="Black" Margin="0,0,0,10"/>
                        <TextBlock Text="Новые автомобили, работы и измененная карта уже на сервере!" Foreground="#8A8F98" FontSize="16" TextWrapping="Wrap" Width="400"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Background="#16181C" Margin="0" >
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBox x:Name="NickNameBox" Width="200" Height="40" Background="#121417" Foreground="White" BorderThickness="0" Padding="15,0" FontSize="16" VerticalContentAlignment="Center" Text="Jake_Toren">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            
                            <Button Width="40" Height="40" Background="#2A2D34" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand" Click="SelectPath_Click" ToolTip="Выбрать папку с игрой">
                                <TextBlock Text="⚙" Foreground="White" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="StatusText" Text="Проверка файлов..." Foreground="#8A8F98" FontSize="12" Margin="0,0,15,0" VerticalAlignment="Center"/>
                            <ProgressBar x:Name="DownloadProgress" Width="250" Height="4" Background="#2A2D34" Foreground="#32CD32" BorderThickness="0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#121417" CornerRadius="10" Height="50" Padding="15,0" VerticalAlignment="Center" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="OnlineIndicator" Width="8" Height="8" Fill="Gray" Margin="0,0,10,0"/> 
                            <TextBlock Text="Flyt RP | Основной" Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock x:Name="OnlineText" Text="? / ?" Foreground="#8A8F98" FontSize="14" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                   </Border>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <CheckBox x:Name="TestModeCheck" Content="Режим проверки (без запуска)" Foreground="#8A8F98" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center" Cursor="Hand"/>
                        <Button Content="ИГРАТЬ ›" Click="Play_Click" Width="200" Height="50" Background="#32CD32" Foreground="White" FontSize="18" FontWeight="Bold" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#32CD32" Opacity="0.4" ShadowDepth="0"/>
                            </Button.Effect>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
